<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Clothify</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.htm</welcome-file>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.xhtml</welcome-file>
        <welcome-file>default.html</welcome-file>
        <welcome-file>default.htm</welcome-file>
        <welcome-file>default.jsp</welcome-file>
        <welcome-file>default.xhtml</welcome-file>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- Home Servlet -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.clothify.HomeServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <!-- Products Servlet -->
    <servlet>
        <servlet-name>ProductsServlet</servlet-name>
        <servlet-class>com.clothify.ProductsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ProductsServlet</servlet-name>
        <url-pattern>/products</url-pattern>
    </servlet-mapping>

    <!-- Add To Cart Servlet -->
    <servlet>
        <servlet-name>AddToCartServlet</servlet-name>
        <servlet-class>com.clothify.AddToCartServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddToCartServlet</servlet-name>
        <url-pattern>/add-cart</url-pattern>
    </servlet-mapping>

    <!-- View Cart Servlet -->
    <servlet>
        <servlet-name>ViewCartServlet</servlet-name>
        <servlet-class>com.clothify.ViewCartServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewCartServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ViewCartServlet</servlet-name>
        <url-pattern>/viewcart</url-pattern>
    </servlet-mapping>

    <!-- Remove Cart Servlet -->
    <servlet>
        <servlet-name>RemoveCartServlet</servlet-name>
        <servlet-class>com.clothify.RemoveCartServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RemoveCartServlet</servlet-name>
        <url-pattern>/remove-cart</url-pattern>
    </servlet-mapping>

    <!-- Checkout Page Servlet -->
    <servlet>
        <servlet-name>CheckoutPageServlet</servlet-name>
        <servlet-class>com.clothify.CheckoutPageServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CheckoutPageServlet</servlet-name>
        <url-pattern>/checkout-page</url-pattern>
    </servlet-mapping>

    <!-- Checkout Servlet -->
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.clothify.CheckoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>

    <!-- Create Cashfree Order Servlet -->
    <servlet>
        <servlet-name>CreateCashfreeOrderServlet</servlet-name>
        <servlet-class>com.clothify.CreateCashfreeOrderServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CreateCashfreeOrderServlet</servlet-name>
        <url-pattern>/create-cashfree-order</url-pattern>
    </servlet-mapping>

    <!-- Cashfree Success Servlet -->
    <servlet>
        <servlet-name>CashfreeSuccessServlet</servlet-name>
        <servlet-class>com.clothify.CashfreeSuccessServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CashfreeSuccessServlet</servlet-name>
        <url-pattern>/cashfree-success</url-pattern>
    </servlet-mapping>

    <!-- Orders Servlet -->
    <servlet>
        <servlet-name>OrdersServlet</servlet-name>
        <servlet-class>com.clothify.OrdersServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OrdersServlet</servlet-name>
        <url-pattern>/orders</url-pattern>
    </servlet-mapping>

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.clothify.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.clothify.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.clothify.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Profile Servlet -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.clothify.ProfileServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>

    <!-- Update Profile Servlet -->
    <servlet>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <servlet-class>com.clothify.UpdateProfileServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <url-pattern>/update-profile</url-pattern>
    </servlet-mapping>

    <!-- Send OTP Servlet -->
    <servlet>
        <servlet-name>SendOtpServlet</servlet-name>
        <servlet-class>com.clothify.SendOtpServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SendOtpServlet</servlet-name>
        <url-pattern>/send-otp</url-pattern>
    </servlet-mapping>

    <!-- Verify OTP Servlet -->
    <servlet>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <servlet-class>com.clothify.VerifyOtpServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>VerifyOtpServlet</servlet-name>
        <url-pattern>/verify-otp</url-pattern>
    </servlet-mapping>

    <!-- Test DB Servlet -->
    <servlet>
        <servlet-name>TestDBServlet</servlet-name>
        <servlet-class>com.clothify.TestDBServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TestDBServlet</servlet-name>
        <url-pattern>/test-db</url-pattern>
    </servlet-mapping>

</web-app>